# Firebase Configuration
# Copy this file to .env.local and fill with your Firebase project credentials
# Get these values from: Firebase Console > Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional: Firebase Emulator Configuration (for local development)
# Uncomment these lines to use Firebase Emulators instead of production
# VITE_USE_EMULATORS=true
# VITE_FIRESTORE_EMULATOR_HOST=localhost:8080
# VITE_AUTH_EMULATOR_HOST=localhost:9099
